#!/bin/bash
set -euo pipefail

LENGTH=${1:-24}

SECRET=$(openssl rand -base64 48 | tr -d '/+=\n' | head -c "$LENGTH")

if [[ ! "$SECRET" =~ ^[a-zA-Z0-9]+$ ]]; then
  echo "Error: generated secret contains non-alphanumeric characters" >&2
  exit 1
fi

if [ ${#SECRET} -ne "$LENGTH" ]; then
  echo "Error: generated secret length mismatch" >&2
  exit 1
fi

B64=$(echo -n "$SECRET" | base64)
VERIFY=$(echo "$B64" | base64 -d)

if [ "$SECRET" != "$VERIFY" ]; then
  echo "Error: base64 encode/decode verification failed" >&2
  exit 1
fi

echo "secret: $SECRET"
echo "base64: $B64"
