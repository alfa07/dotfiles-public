#!/bin/bash

# Usage: ./stow_config.sh <config_name>
# Example: ./stow_config.sh atuin

set -e  # Exit on any error

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <config_name>"
    echo "Example: $0 atuin"
    exit 1
fi

CONFIG_NAME="$1"
DOTFILES_DIR="$HOME/dotfiles4"
CONFIG_SOURCE="$HOME/.config/$CONFIG_NAME"
STOW_CONFIG_DIR="$DOTFILES_DIR/$CONFIG_NAME/.config/$CONFIG_NAME"

# Check if source config exists
if [ ! -e "$CONFIG_SOURCE" ]; then
    echo "Error: Config directory $CONFIG_SOURCE does not exist!"
    exit 1
fi

# Check if source config is empty
if [ -z "$(ls -A "$CONFIG_SOURCE")" ]; then
    echo "Error: Config directory $CONFIG_SOURCE is empty!"
    exit 1
fi

# Check if dotfiles directory exists
if [ ! -d "$DOTFILES_DIR" ]; then
    echo "Error: Dotfiles directory $DOTFILES_DIR does not exist!"
    exit 1
fi

# Create backup with incrementing number
backup_dir=""
counter=0
while true; do
    backup_dir="$CONFIG_SOURCE.bak.$counter"
    if [ ! -e "$backup_dir" ]; then
        break
    fi
    ((counter++))
done

echo "Creating backup at $backup_dir..."
if ! rsync -a "$CONFIG_SOURCE/" "$backup_dir/"; then
    echo "Error: Backup failed"
    exit 1
fi

# Create the directory structure in dotfiles
echo "Creating directory structure in $STOW_CONFIG_DIR..."
mkdir -p "$STOW_CONFIG_DIR"

# Move all files, including hidden ones
echo "Moving config files from $CONFIG_SOURCE to $STOW_CONFIG_DIR..."
shopt -s dotglob  # Enable matching hidden files
files_to_move=("$CONFIG_SOURCE"/*)
if [ ${#files_to_move[@]} -eq 0 ]; then
    echo "Error: No files found to move in $CONFIG_SOURCE"
    exit 1
fi

for file in "${files_to_move[@]}"; do
    if ! mv -v "$file" "$STOW_CONFIG_DIR/"; then
        echo "Error: Failed to move $file"
        echo "Backup is still available at: $backup_dir"
        exit 1
    fi
done
shopt -u dotglob  # Disable matching hidden files

# Verify the source directory is empty before removing
if [ -n "$(ls -A "$CONFIG_SOURCE")" ]; then
    echo "Error: Source directory not empty after move. Something went wrong."
    echo "Backup is still available at: $backup_dir"
    exit 1
fi

# Remove the original (now empty) directory
echo "Removing empty original directory..."
if ! rm -rf "$CONFIG_SOURCE"; then
    echo "Error: Failed to remove original directory"
    echo "Backup is still available at: $backup_dir"
    exit 1
fi

# Run stow
echo "Running stow..."
cd "$DOTFILES_DIR" || exit 1
if ! stow "$CONFIG_NAME"; then
    echo "Error: Stow command failed"
    echo "Backup is still available at: $backup_dir"
    exit 1
fi

# Verify the symlink
if [ -L "$CONFIG_SOURCE" ]; then
    echo "Success! Config files moved and stow symlink created."
    echo "Backup created at: $backup_dir"
    echo "Your $CONFIG_NAME config is now managed by stow."
else
    echo "Warning: Symlink wasn't created. Something might have gone wrong."
    echo "Your backup is still available at: $backup_dir"
    exit 1
fi
