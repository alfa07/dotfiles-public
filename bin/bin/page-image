#!/usr/bin/env rust-script
//! ```cargo
//! [dependencies]
//! image = "0.25"
//! clap = { version = "4", features = ["derive"] }
//! log = "0.4"
//! env_logger = "0.11"
//! ```

use clap::Parser;
use image::GenericImageView;
use log::{debug, info};
use std::path::PathBuf;

#[derive(Parser, Debug)]
#[command(about = "Split a tall image into overlapping pages")]
struct Args {
    /// Path to the image file
    image: PathBuf,

    /// Max pixel height of each page
    #[arg(long, default_value_t = 1080)]
    page_height: u32,

    /// Pixel overlap between consecutive pages
    #[arg(long, default_value_t = 20)]
    overlap: u32,
}

fn main() {
    env_logger::Builder::from_env(env_logger::Env::default().default_filter_or("info")).init();

    let args = Args::parse();
    debug!("args: {:?}", args);

    let img = image::open(&args.image).expect("failed to open image");
    let (w, h) = img.dimensions();
    info!("image: {}x{} px", w, h);

    let step = args.page_height - args.overlap;
    debug!("step: {} px  (page_height={} overlap={})", step, args.page_height, args.overlap);

    let stem = args.image.file_stem().unwrap().to_string_lossy();
    let ext = args.image.extension().unwrap_or_default().to_string_lossy();
    let dir = args.image.parent().unwrap_or_else(|| std::path::Path::new("."));

    let mut i = 0u32;
    loop {
        let top = i * step;
        if top >= h {
            break;
        }
        let bottom = (top + args.page_height).min(h);
        let page_h = bottom - top;

        debug!("page {}: rows {}..{} ({}px tall)", i, top, bottom, page_h);

        let page = img.crop_imm(0, top, w, page_h);

        let out = dir.join(format!("{}-{}.{}", stem, i, ext));
        page.save(&out).expect("failed to save page");
        info!("wrote {}", out.display());

        i += 1;
    }

    info!("done: {} pages", i);
}
