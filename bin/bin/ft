#!/usr/bin/env rust-script
//! Git feature-clone (and legacy worktree) management tool.
//!
//! Implementation lives in the sibling `ftlib` crate; rust-script resolves the
//! relative `path` dependency against this script's own directory.
//!
//! ```cargo
//! [dependencies]
//! ftlib = { path = "./ftlib" }
//! ```

fn main() -> std::process::ExitCode {
    ftlib::run()
}
